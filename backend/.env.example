# Environment Configuration Template
# Copy this file to .env and fill in your actual values

# Backend
PORT=5000
NODE_ENV=development
JWT_SECRET=your-secret-key-change-in-production

# Google Sheets Integration (REQUIRED for full functionality)
# Get your Sheet ID from URL: https://docs.google.com/spreadsheets/d/[SHEET_ID]/edit
GOOGLE_SHEET_ID=your-sheet-id-here

# Google Cloud Service Account Credentials
# Option A: Paste entire JSON credentials (secured in .env)
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key":"..."}

# Option B: Use credentials file (add credentials.json to .gitignore)
# GOOGLE_CREDENTIALS_PATH=./credentials.json

# Frontend API
REACT_APP_API_URL=http://localhost:5000

