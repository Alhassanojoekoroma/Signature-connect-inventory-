    "2_database_schema_updates": {
      "description": "Added activity_logs table and auto-logging triggers to Supabase",
      "file": "SUPABASE_SCHEMA.sql",
      "changes": [
        {
          "action": "add_table",
          "table_name": "activity_logs",
          "columns": [
            "id UUID PRIMARY KEY",
            "user_name TEXT NOT NULL",
            "user_id UUID REFERENCES users(id)",
            "action TEXT NOT NULL",
            "product_id UUID REFERENCES products(id)",
            "product_name TEXT",
            "serial_number TEXT REFERENCES items(serial_number)",
            "message TEXT NOT NULL",
            "additional_data JSONB",
            "created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP"
          ]
        },
        {
          "action": "add_indexes",
          "indexes": [
            "idx_activity_logs_user_id",
            "idx_activity_logs_product_id",
            "idx_activity_logs_serial_number",
            "idx_activity_logs_action",
            "idx_activity_logs_created_at"
          ]
        },
        {
          "action": "add_rls_policy",
          "policy_name": "All authenticated users can view activity logs",
          "operation": "SELECT",
          "condition": "auth.role() = 'authenticated'"
        },
        {
          "action": "add_rls_policy",
          "policy_name": "System can insert activity logs",
          "operation": "INSERT",
          "condition": "true"
        },
        {
          "action": "add_trigger",
          "trigger_name": "trigger_log_activity_on_transaction",
          "function": "log_activity_on_transaction()",
          "event": "AFTER INSERT ON transactions",
          "purpose": "Auto-generate activity messages on transaction creation"
        }
      ]
    },

    "3_activity_logging_service": {
      "description": "New service module for activity logging and retrieval",
      "file": "frontend/src/services/activityLogService.js",
      "type": "new_file",
      "size": "280 lines",
      "exports": [
        "logLoginActivity(userId, userName)",
        "logProductViewActivity(userId, userName, productId, productName)",
        "logItemViewActivity(userId, userName, serialNumber)",
        "getAllActivityLogs(page, limit)",
        "getProductActivityLogs(productId, limit)",
        "getItemActivityLogs(serialNumber, limit)",
        "getUserActivityLogs(userId, limit)",
        "getActivityLogsByAction(action, limit)",
        "getActivityLogsByDateRange(startDate, endDate, limit)",
        "getActivityStats()",
        "exportActivityLogsAsJSON(logs)",
        "formatActivityLogForDisplay(log)"
      ],
      "auto_tracked_actions": [
        {
          "action": "LOGIN",
          "message": "USERNAME logged into the system",
          "triggered_by": "AuthContext.login()"
        },
        {
          "action": "VIEW_PRODUCT",
          "message": "USERNAME viewed PRODUCT_NAME",
          "triggered_by": "Component navigation"
        },
        {
          "action": "VIEW_ITEM",
          "message": "USERNAME viewed item SERIAL_NUMBER",
          "triggered_by": "Component navigation"
        },
        {
          "action": "ADD_STOCK",
          "message": "USERNAME added X PRODUCT_NAME to stock",
          "triggered_by": "Database trigger"
        },
        {
          "action": "ISSUE",
          "message": "USERNAME issued SERIAL_NUMBER to CUSTOMER_NAME",
          "triggered_by": "Database trigger"
        },
        {
          "action": "RETURN",
          "message": "USERNAME returned SERIAL_NUMBER (CONDITION)",
          "triggered_by": "Database trigger"
        },
        {
          "action": "MARK_FAULTY",
          "message": "USERNAME marked SERIAL_NUMBER as faulty",
          "triggered_by": "Database trigger"
        },
        {
          "action": "VIEW",
          "message": "USERNAME scanned item SERIAL_NUMBER",
          "triggered_by": "Database trigger"
        }
      ]
    },

